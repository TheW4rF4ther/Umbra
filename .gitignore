# Blackbox Umbra .gitignore

# Python cache & compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/

# IDE & editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# Engagement outputs & sensitive data
engagements/
results/
*.json
findings.json
engagement.json
report.md
*.xml
*.txt

# Wordlists (typically large, external)
wordlists/

# Local configuration
.env
.env.local
*.config
config.local.yml

# OS-specific
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# Temporary files
*.tmp
*.bak
*.backup
*.old

# Logs
*.log
logs/

# Security keys, credentials
*.key
*.pem
*.crt
*.p12
*.pfx
.ssh/
credentials.json
secrets.json
.aws/
.azure/

# Do NOT commit engagement data
/engagements/**
!/engagements/.gitkeep

# Compiled nmap outputs
*.nessus
*.gnmap

# Large tool outputs
/recon/
/enum/
/ad/
/vulns/
